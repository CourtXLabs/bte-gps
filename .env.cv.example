# BTE Computer Vision API - Environment Variables Reference
# Use this when integrating with or running the BTE Computer Vision API
# Source: bte-computer-vision repo

# Database Configuration (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# Model Paths
YOLO_MODEL_PATH=./models/yolov8n.pt
MEDIAPIPE_MODEL_PATH=./models/pose_landmarker.task

# Processing Settings
VIDEO_FPS=15
INPUT_RESOLUTION=640x640

# Output Settings
OUTPUT_FORMAT=json
CONFIDENCE_THRESHOLD=0.5

# Optional: External API Keys
# ESPN_API_KEY=your-key
# BASKETBALL_REFERENCE_API_KEY=your-key
